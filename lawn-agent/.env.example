# Satellite imagery + geocoding — https://account.mapbox.com/access-tokens/ (50,000 free static images/month)
MAPBOX_TOKEN=

# Address sourcing — free default. https://developer.domain.com.au -> create an app
DATA_SOURCE=domain
DOMAIN_CLIENT_ID=
DOMAIN_CLIENT_SECRET=

# AI vision scoring + lawn condition classification — https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_VISION_MODEL=google/gemini-2.5-flash

# Photoreal lawn render — Google AI Studio (Gemini 2.5 Flash Image), free tier
# https://aistudio.google.com/apikey
GOOGLE_AI_STUDIO_API_KEY=

# Postcard print + mail dispatch — not configured yet, disabled in the workflow
# https://www.postgrid.com/
POSTGRID_API_KEY=
POSTGRID_ENV=test

# Paid path (future): set DATA_SOURCE=apify to use this instead of Domain
APIFY_TOKEN=
APIFY_ACTOR_ID=abotapi~realestate-au-scraper

# Output sheet logging
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
