# Satellite imagery — https://account.mapbox.com/access-tokens/ (50,000 free static images/month)
MAPBOX_TOKEN=

# AI vision scoring + lawn condition classification — https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_VISION_MODEL=google/gemini-2.5-flash

# Photoreal lawn render (image edit) — https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1

# Postcard print + mail dispatch — https://www.postgrid.com/
POSTGRID_API_KEY=
POSTGRID_ENV=test

# Optional: property/address sourcing via Apify actor (real estate listing scrape)
APIFY_TOKEN=
APIFY_ACTOR_ID=

# Output sheet logging
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
